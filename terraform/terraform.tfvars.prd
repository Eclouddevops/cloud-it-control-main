# PRD (Production) Environment Configuration
# Branch: main → deploys here automatically via GitHub Actions
# Purpose: Live customer-facing environment — treat with care

aws_region         = "ap-south-1"
environment        = "prd"
domain_name        = "app.cloud-it-control.example.com"
certificate_domain = "cloud-it-control.example.com"
enable_waf         = true               # WAF mandatory in production

# Supabase — production project (never share with lower environments)
supabase_project_id      = "REPLACE_WITH_PRD_SUPABASE_PROJECT_ID"
supabase_url             = "https://REPLACE_WITH_PRD_SUPABASE_PROJECT_ID.supabase.co"
supabase_publishable_key = "REPLACE_WITH_PRD_SUPABASE_ANON_KEY"
