# Development Environment Configuration
# Copy this file to terraform.tfvars and update with your values

aws_region              = "ap-south-1"
environment             = "dev"
domain_name             = "dev.cloud-it-control.example.com"
certificate_domain      = "cloud-it-control.example.com"
enable_waf              = false

# Supabase Configuration
supabase_project_id     = "REPLACE_WITH_DEV_SUPABASE_PROJECT_ID"
supabase_url            = "https://REPLACE_WITH_DEV_SUPABASE_PROJECT_ID.supabase.co"
supabase_publishable_key = "REPLACE_WITH_DEV_SUPABASE_ANON_KEY"
