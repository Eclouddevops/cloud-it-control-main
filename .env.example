# Environment Variables Example

# These variables are used by the Vite build process
# Copy this file to .env and fill in with your actual values
# Never commit .env to version control!

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# AWS Configuration (optional, for local deployment testing)
# These should be in GitHub Secrets, not in .env
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
